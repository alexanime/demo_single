TELEGRAM_TOKEN=your_demo_bot_token_here
# In demo mode the Admin role is hidden, bookings are never written to DB and
# no admin notifications are sent. Set DEMO_MODE=0 to run as a regular booking
# bot (then OWNER_ID and MASTER_CONTACT below take effect normally).
DEMO_MODE=1
# Telegram username shown in CTA messages, e.g. "Хотите такого же бота? Напишите @al_username"
DEMO_USERNAME=@al_username
# URL the «О тарифах» button and /start intro point to (e.g. your sales channel).
DEMO_TARIFFS_URL=https://t.me/your_channel

# Только для DEMO_MODE=0:
OWNER_ID=123456789
MASTER_CONTACT=Телефон/адрес/ссылка мастера
BOT_DB_PATH=bot.db
